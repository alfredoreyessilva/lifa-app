{
  "installCommand": "npm install --force",
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/partidos/:matchId", "destination": "/api/social-preview?type=match&matchId=:matchId" },
    { "source": "/ligas/:slug", "destination": "/api/social-preview?type=league&slug=:slug" },
    { "source": "/categorias/:categoryId/calendario", "destination": "/api/social-preview?type=calendar&categoryId=:categoryId" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}